# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_intel

# Application
APP_ENV=development
DEBUG=true

# Zerodha (leave empty until credentials are available)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Broker mode: "mock" or "zerodha"
BROKER_MODE=mock
