# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_intel

# Application
APP_ENV=development
DEBUG=true

# Zerodha (leave empty until credentials are available)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Broker mode: "mock" or "zerodha"
BROKER_MODE=mock

# Gemini API Key (get from https://ai.google.dev/gemini-api/docs/get-started/tutorial)
# Format: alphanumeric string, typically 40+ characters (NOT starting with AQ., AI_, etc.)
GEMINI_API_KEY=your_actual_google_generativeai_api_key_here
